# CogNexus 环境配置
# 复制此文件为 .env 并修改配置

# ===== 服务配置 =====

# 监听地址
HUB_HOST=0.0.0.0

# 监听端口
HUB_PORT=8080

# ===== 安全配置（必须修改！）=====

# JWT 密钥（用于用户认证）
# 生成方式: openssl rand -hex 32
JWT_SECRET=your-random-secret-key-change-this-immediately

# JWT 过期时间（小时）
JWT_EXPIRE_HOURS=168

# ===== 数据库配置 =====

# SQLite 数据库路径
DATABASE_PATH=data/hub.db

# ===== 业务配置 =====

# 新用户初始 ATP 积分
INITIAL_ATP=100

# ===== 可选配置 =====

# 日志级别
# LOG_LEVEL=INFO

# 允许的 CORS 来源（逗号分隔）
# CORS_ORIGINS=http://localhost:3000,https://your-domain.com
